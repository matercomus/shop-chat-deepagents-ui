REDIRECT_URL=https://localhost:3458/auth/callback
SHOPIFY_API_KEY=YOUR_APP_CLIENT_ID

# DeepAgents sync endpoint (ADR 0015 / plan 0002). The app server proxies each
# storefront turn to POST {DEEPAGENTS_URL}/shopify/agent/{DEEPAGENTS_BRAND}.
# In dev this is the local main.py endpoint (no auth). In prod/preview, leave
# this as-is (or unset) and instead set SHOPIFY_AGENT_SHIM_* below.
DEEPAGENTS_URL=http://localhost:8000
DEEPAGENTS_BRAND=lux3three

# Cloud Shopify sync shim (issue #8 / ADR 0017 — ponhu_chat_agent #309/#310).
# The deployed AgentCore Shopify backend is SigV4-only with no public URL; the
# shim is a public, bearer-authenticated HTTPS endpoint the app SERVER calls
# (server-to-server, never the browser). Set BOTH in prod/preview to switch the
# target from local main.py to the cloud runtime. Leave BOTH unset in dev.
#   - SHOPIFY_AGENT_SHIM_URL wins over DEEPAGENTS_URL when set.
#   - SHOPIFY_AGENT_SHIM_TOKEN is a shared secret obtained out-of-band from the
#     backend operator (it is NOT readable by this app). NEVER expose it to the
#     client bundle — it is read only in *.server.js modules.
# Example: SHOPIFY_AGENT_SHIM_URL=https://<api-id>.execute-api.us-east-1.amazonaws.com
SHOPIFY_AGENT_SHIM_URL=
SHOPIFY_AGENT_SHIM_TOKEN=
# Server-trusted shop domain. The deepagents endpoint is config-authoritative on
# shop_domain, so set this to the launch store's domain in non-dev environments.
# Must be a NON-password (publicly accessible) store for the UCP client to work.
SHOPIFY_SHOP_DOMAIN=
